{
  "name": "agent-browser",
  "version": "1.0.0",
  "description": "AgentBrowser — Multi-agent macOS browser with VPN/proxy and automation",
  "main": "dist/main/index.js",
  "scripts": {
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "dist:dmg": "npm run build && electron-builder --mac dmg --x64"
  },
  "keywords": ["electron", "browser", "agent", "vpn", "proxy", "macos"],
  "author": "AgentBrowser",
  "license": "MIT",
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  }
}
